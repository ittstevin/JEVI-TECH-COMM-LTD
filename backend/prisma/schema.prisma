// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPPORT
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InstallationStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum NetworkStatusType {
  OPERATIONAL
  DEGRADED
  OUTAGE
  MAINTENANCE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  address   String?
  role      UserRole @default(CUSTOMER)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions  Subscription[]
  payments       Payment[]
  tickets        SupportTicket[]
  installations  InstallationRequest[]
  notifications  Notification[]
  testimonials   Testimonial[]

  @@map("users")
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  speed       Int      // Mbps
  price       Float
  description String?
  features    String   // JSON string of features array
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  planId      String
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  renewalDate DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  amount         Float
  paymentMethod  String
  status         PaymentStatus @default(PENDING)
  transactionId  String?       @unique
  invoiceUrl     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  priority  String?      @default("normal")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model InstallationRequest {
  id                       String             @id @default(cuid())
  userId                   String
  address                  String
  locationCoordinates      String?            // JSON string for lat/lng
  selectedPlan             String
  preferredInstallationDate DateTime?
  status                   InstallationStatus @default(PENDING)
  technicianNotes          String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("installation_requests")
}

model NetworkStatus {
  id        String            @id @default(cuid())
  area      String
  status    NetworkStatusType @default(OPERATIONAL)
  message   String?
  updatedAt DateTime          @updatedAt
  createdAt DateTime          @default(now())

  @@map("network_status")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String   // email, sms, push
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String
  message   String
  rating    Int?     // Optional 1-5 rating
  approved  Boolean  @default(false) // Requires admin approval
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("testimonials")
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("messages")
}

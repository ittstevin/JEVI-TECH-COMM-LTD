rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection - users can read/write their own data, admins can read all
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated();
    }

    // Subscriptions - users can read their own, admins can read/write all
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    // Tickets - users can read/write their own, admins can read/write all
    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    // Messages - users can read/write their own, admins can read/write all
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    // Testimonials - anyone can read approved ones, authenticated users can create, admins can manage all
    match /testimonials/{testimonialId} {
      allow read: if resource.data.approved == true || (isAuthenticated() && isAdmin());
      allow write: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }

    // Service Status - everyone can read, only admins can write
    match /serviceStatus/{statusId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isAdmin();
    }

    // Plans - everyone can read, only admins can write
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && isAdmin();
    }

    // Payments - users can read their own, admins can read all
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    // Installations - users can read their own, admins can read/write all
    match /installations/{installationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }
  }
}